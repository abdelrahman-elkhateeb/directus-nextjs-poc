# Copy this file to .env and adjust values for your environment.
# Docker Compose automatically loads .env from this directory.

POSTGRES_USER=directus
POSTGRES_PASSWORD=directus
POSTGRES_DB=directus

# Use a long random value in non-local environments.
SECRET=replace-this-with-a-long-random-secret

# Used by Directus only when initializing a brand-new database.
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=admin123
